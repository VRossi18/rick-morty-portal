# Rick and Morty Portal — copy to .env for local dev

# Polygon donation contract (required for crypto tab)
VITE_DONATION_CONTRACT_ADDRESS=

# Optional Polygon RPC override
# VITE_POLYGON_RPC_URL=https://polygon-rpc.com

# Optional WalletConnect (future)
# VITE_WALLETCONNECT_PROJECT_ID=

# --- AI curiosities (character detail page) ---

# Frontend: URL of the BFF endpoint (never put LLM_API_KEY here)
# Local dev with Vite proxy: /api/ai/character-curiosity
# GitHub Pages build: https://<cloud-run-host>/api/ai/character-curiosity
VITE_AI_API_URL=/api/ai/character-curiosity

# Server: read automatically by server/src/loadEnv.ts (also works from server/.env)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
ALLOWED_ORIGINS=http://localhost:5173

# Quick start: pnpm run dev:all
