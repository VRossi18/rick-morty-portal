# Rick and Morty Portal — copy to .env for local dev

# Polygon donation contract (required for crypto tab)
VITE_DONATION_CONTRACT_ADDRESS=

# Optional Polygon RPC override
# VITE_POLYGON_RPC_URL=https://polygon-rpc.com

# Optional WalletConnect (future)
# VITE_WALLETCONNECT_PROJECT_ID=

# Stripe PIX checkout API (frontend)
# Cloud Run (same origin): /api/stripe/create-checkout-session
# GitHub Pages: https://<cloud-run-host>/api/stripe/create-checkout-session
# VITE_STRIPE_CHECKOUT_API_URL=

# Server-only (local: cd server && pnpm dev) — never commit real keys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# ALLOWED_ORIGINS=http://localhost:5173
